# clawd-gateway open x402 configuration

PORT=8402
HOST=0.0.0.0
PUBLIC_URL=http://127.0.0.1:8402

# Pay-to addresses (where micropayments settle)
X402_PAY_TO_EVM=0xYourEvmTreasuryAddress
X402_PAY_TO_SOLANA=YourSolanaTreasuryPubkey

# Optional facilitator (Coinbase CDP / x402.org) — required for real settlement
# X402_FACILITATOR_URL=https://x402.org/facilitator

# Offline test payments (x402Test:true). NEVER enable in production.
# X402_ALLOW_TEST_PAYMENTS=0

# Upstream provider keys (server-side only — clients never see these)
# OPENROUTER_API_KEY=
# COINGECKO_API_KEY=

# Fallbacks when upstreams are unavailable (default: allow)
# X402_ALLOW_PRICE_FALLBACK=1
# X402_ALLOW_LLM_FALLBACK=1
# X402_ALLOW_SCRAPE_FALLBACK=1
# X402_FORCE_LLM_FALLBACK=0
